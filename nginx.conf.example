# FileForge Nginx site config.
# Copy to /etc/nginx/sites-available/fileforge, adjust server_name/root,
# then: ln -s ../sites-available/fileforge /etc/nginx/sites-enabled/
#       nginx -t && systemctl reload nginx
# Once a domain points here, run certbot --nginx for SSL.

server {
    listen 80;
    listen [::]:80;
    server_name _;  # replace with your domain, e.g. fileforge.example.com

    root /var/www/fileforge/frontend/dist;
    index index.html;

    # Upload cap: slightly above the app's 50MB limit so the app,
    # not Nginx, produces the friendly "file too large" error.
    client_max_body_size 55M;

    gzip on;
    gzip_vary on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;

    # API -> Express on 8095
    location /api/ {
        proxy_pass http://127.0.0.1:8095;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 180s;   # conversions can take up to 120s
    }

    # Hashed build assets can be cached forever.
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # SPA fallback: every tool route serves the React app.
    location / {
        try_files $uri /index.html;
    }
}
